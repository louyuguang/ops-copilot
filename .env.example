# Analysis mode: rule | llm
ANALYSIS_MODE=rule

# OpenAI-compatible LLM settings (used when ANALYSIS_MODE=llm)
OPENAI_API_KEY=
OPENAI_MODEL=sub2api/gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1

# Retriever mode: local | chroma
RETRIEVER_MODE=local
CHROMA_TOP_K=3
CHROMA_HOST=localhost
CHROMA_PORT=18000
CHROMA_COLLECTION=opscopilot_cards_v1
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Debug observability (0/1). When enabled, metadata is printed to stderr.
OPSCOPILOT_DEBUG=0
